# ==============================================
# BUDGET BUCKETS - SERVER ENVIRONMENT VARIABLES
# ==============================================
# Copy this to .env and fill in your actual values
# NEVER commit .env to version control

# --- Server ---
NODE_ENV=development
PORT=3001

# --- PostgreSQL Database ---
# Railway provides this automatically when you add a Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/budget_buckets

# --- Plaid (https://dashboard.plaid.com/developers/keys) ---
# CRITICAL: These keys must NEVER be in the client/mobile app
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret_sandbox_key
PLAID_ENV=sandbox

# --- Firebase Admin SDK ---
# Download from Firebase Console > Project Settings > Service Accounts
# Option 1: Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option 2: Individual values (for Railway/cloud deploy)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYour key here\n-----END RSA PRIVATE KEY-----\n"

# --- Security ---
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
